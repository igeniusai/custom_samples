# -----------------------------------------------------------------------------
# hermes-platform-gateway — deployment env vars
# Copy to .env and fill in.
# -----------------------------------------------------------------------------

# --- Domyn platform (required) -----------------------------------------------
# API key with worker rights on the channel (must be different from a
# read-only HTTP key — the WS relay rejects keys without subscriber scope).
DOMYN_API_KEY=

# Platform host. Can be bare ("conv2.crystal.io") or include a scheme
# ("https://conv2.crystal.io") — the plugin normalises both.
DOMYN_BASE_URL=

# The space and channel this hermes worker serves.
DOMYN_SPACE_ID=
DOMYN_CHANNEL_ID=

# Optional — pin tool discovery to a specific configuration. Omit to use
# the channel's active configuration.
# DOMYN_CONFIGURATION_ID=

# --- Plugin tuning (optional) ------------------------------------------------
# Per-platform-tool timeout in seconds. Default 120.
# PLATFORM_TOOL_TIMEOUT=120
# Canvas tool-list poll interval in seconds. Set to 0 to disable. Default 60.
# PLATFORM_TOOL_REFRESH_INTERVAL=60

# --- LLM provider (required by hermes itself) --------------------------------
# Hermes needs at least one model provider. Defaults below target the
# vLLM gateway used by the example agents in `custom_samples`; swap for
# OpenRouter / OpenAI / Anthropic / Ollama by changing both vars.
VLLM_API_KEY=
VLLM_BASE_URL=https://gateway-dev.llm.crystal.ai/v1
VLLM_MODEL=Qwen/Qwen3-32B

# --- Logging (optional) ------------------------------------------------------
# Set to 1 to surface plugin-discovery debug logs on stderr.
# HERMES_PLUGINS_DEBUG=0
